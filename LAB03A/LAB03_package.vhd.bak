library ieee;
use ieee. std_logic_1164. all;
package LAB03_package is
	component fulladd
		port( cin, x, y : in std_logic;
				S, Cout : out std_logic);
	end component fulladd;

	component hex
		port( w, x, y, z : in std_logic;
		a, b, c, d, e, f, g : out std_logic);
	end component hex;

end LAB03_package;