library ieee ;
use ieee_std_logic_1164.all;
package lab2_package is
	component fulladder 
		port( cin , x, y: in std_logic ;
				s, cout : out std_logic);
	end component fulladder
	
	component hex
		port (sw0,swl,sw2,sw3,sw4,sw5,sw6,sw7: in std_logic;
				al,b1,cl,dl,el,f1,g1,a2,b2,c2,d2,e2,f2,g2: out std_logic);
	END component hex;
END lab2_package;